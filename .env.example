# =================================
# CLIMBY — Environment Variables
# =================================
# Скопируй этот файл в .env и подмени значения
# .env в .gitignore, в репо НЕ попадёт

# Supabase (бери в Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Telegram Bot (если используешь TG-авторизацию)
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF...
TELEGRAM_BOT_USERNAME=climby_league_bot

# Service Role (только для Edge Functions / админ-скриптов)
# ВНИМАНИЕ: НИКОГДА не коммить этот ключ в git
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Прод URL (для CORS и редиректов)
APP_URL=https://climby.app
